				; Loads quiz questions
				; IN: eax = 0=easy, 1=med, 2=hard
 000001CA			LoadQuiz PROC
 000001CA  50			    push eax
 000001CB  53			    push ebx
 000001CC  51			    push ecx
 000001CD  52			    push edx
 000001CE  56			    push esi

				    .if eax == 0
 000001D3  BA 00000000 R	        mov edx, OFFSET quizFileEasy
				    .elseif eax == 1
 000001DF  BA 00000018 R	        mov edx, OFFSET quizFileMed
				    .else
 000001E6  BA 0000002F R	        mov edx, OFFSET quizFileHard
				    .endif
 000001EB  E8 00000000 E	    call OpenInputFile

 000001F0  BA 0000008B R	    mov edx, OFFSET quizBuffer
 000001F5  B9 000007CF		    mov ecx, QUESTION_BUF_SIZE - 1
 000001FA  E8 00000000 E	    call ReadFromFile
 000001FF  A3 0000085B R	    mov quizBytesRead, eax
 00000204  C6 80 0000008B R	    mov BYTE PTR [quizBuffer + eax], 0
	   00

 0000020B  E8 FFFFFDF0		    call ParseQuiz

 00000210  5E			    pop esi
 00000211  5A			    pop edx
 00000212  59			    pop ecx
 00000213  5B			    pop ebx
 00000214  58			    pop eax
 00000215  C3			    ret
 00000216			LoadQuiz ENDP

