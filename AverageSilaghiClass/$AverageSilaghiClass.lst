				    .elseif eax == 1
 000001DF  BA 00000018 R	        mov edx, OFFSET quizFileMed
				    .else
 000001E6  BA 00000032 R	        mov edx, OFFSET quizFileHard
				    .endif
 000001EB  E8 00000000 E	    call OpenInputFile
 000001F0  50				push eax

 000001F1  BA 00000091 R	    mov edx, OFFSET quizBuffer
 000001F6  B9 000007CF		    mov ecx, QUESTION_BUF_SIZE - 1
 000001FB  E8 00000000 E	    call ReadFromFile
 00000200  A3 00000861 R	    mov quizBytesRead, eax
 00000205  C6 80 00000091 R	    mov BYTE PTR [quizBuffer + eax], 0
	   00

 0000020C  58				pop eax
 0000020D  E8 00000000 E		call CloseFile

 00000212  E8 FFFFFDE9		    call ParseQuiz

 00000217  5E			    pop esi
 00000218  5A			    pop edx
 00000219  59			    pop ecx
 0000021A  5B			    pop ebx
 0000021B  58			    pop eax
 0000021C  C3			    ret
 0000021D			LoadQuiz ENDP

